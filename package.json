{
  "author": "Koichi Suematsu",
  "license": "MIT",
  "name": "ibs_th1",
  "description": "Library to process data broadcasted from IBS-TH1 / IBS-TH1 mini / IBS-TH1 Plus.",
  "version": "2.0.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/pascaljp/ibs_th1.git"
  },
  "bugs": {
    "url": "https://github.com/pascaljp/ibs_th1/issues"
  },
  "keywords": [
    "inkbird",
    "ibs-th1"
  ],
  "main": "dist/ibs_th1.js",
  "types": "dist/ibs_th1.d.ts",
  "exports": {
    ".": {
      "types": "./dist/ibs_th1.d.ts",
      "require": "./dist/ibs_th1.js",
      "default": "./dist/ibs_th1.js"
    },
    "./parser": {
      "types": "./dist/parser.d.ts",
      "require": "./dist/parser.js",
      "default": "./dist/parser.js"
    },
    "./dist/ibs_th1": {
      "types": "./dist/ibs_th1.d.ts",
      "require": "./dist/ibs_th1.js",
      "default": "./dist/ibs_th1.js"
    },
    "./dist/ibs_th1.js": "./dist/ibs_th1.js",
    "./dist/parser": {
      "types": "./dist/parser.d.ts",
      "require": "./dist/parser.js",
      "default": "./dist/parser.js"
    },
    "./dist/parser.js": "./dist/parser.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test tests/*.test.ts && npm run build && node tests/package-smoke.cjs",
    "test:manual": "tsx tests/sample.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "dependencies": {
    "log4js": "^6.9.1"
  },
  "peerDependencies": {
    "@abandonware/noble": "^1.9.2-26"
  },
  "peerDependenciesMeta": {
    "@abandonware/noble": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
